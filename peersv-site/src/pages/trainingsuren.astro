---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

/*
  Vul per leeftijdscategorie de trainingsdagen en het uur in.
  `dagen` is een array: één item per trainingsmoment. Bij twee trainingen per week
  zet je gewoon twee strings in de array — die worden dan onder elkaar getoond.
  Notes die met "Tweede training" beginnen worden subtieler gestyled en als HTML
  gerenderd, zodat er een link in kan (zie `techniektrainingNote`).
  Trainer is optioneel; gebruik null zolang die nog niet bekend is.
  Volgorde in de array = volgorde op de pagina.
*/
const techniektrainingNote =
  'Tweede training is techniektraining (Topsoccer) op maandag gegeven door gediplomeerde trainers van <a href="https://top4all.be/topsoccer" target="_blank" rel="noopener noreferrer" class="font-semibold text-white underline decoration-club-yellow decoration-2 underline-offset-4 transition hover:text-club-yellow">Top4All</a> (enkel voor ingeschreven leden)';

const categories: ReadonlyArray<{
  categorie: string;
  dagen: ReadonlyArray<string>;
  trainer: string | null;
}> = [
  { categorie: 'U6 - U7', dagen: ['Woensdag 15u00 - 16u00'], trainer: null },
  {
    categorie: 'U8',
    dagen: ['Vrijdag 17u30 - 18u45', techniektrainingNote],
    trainer: null,
  },
  {
    categorie: 'U10',
    dagen: ['Vrijdag 18u45 - 20u00', techniektrainingNote],
    trainer: null,
  },
  {
    categorie: 'U11',
    dagen: ['Vrijdag 16u45 - 18u00', techniektrainingNote],
    trainer: null,
  },
  {
    categorie: 'U12',
    dagen: ['Donderdag 18u30 - 20u00', techniektrainingNote],
    trainer: null,
  },
  {
    categorie: 'U14',
    dagen: ['Maandag 18u30 - 20u00', 'Donderdag 18u30 - 20u00'],
    trainer: null,
  },
  {
    categorie: 'U17',
    dagen: ['Dinsdag 18u00 - 19u30', 'Donderdag 18u00 - 19u30'],
    trainer: null,
  },
];

// TODO: aanpassen zodra de jeugdwerking de definitieve startdatum doorgeeft
const startdatum = 'Eerste week van augustus';
const locatie = 'Sportcentrum de Deuster, Deusterstraat 74C, 3990 Peer';
const jeugdEmail = 'jeugd@kpeersv.be';
---

<Layout
  title="Trainingsuren jeugd — K. Peer SV"
  description="Overzicht van de jeugd-trainingsuren bij K. Peer SV. Trainingsdagen en -uren per leeftijdscategorie."
  canonical="https://kpeersv.be/trainingsuren"
>
  <Header />
  <main id="main" class="bg-ink-deep text-white">
    <section class="relative isolate overflow-hidden bg-ink-deep">
      <div
        class="pointer-events-none absolute -right-24 -top-24 -z-10 h-[420px] w-[420px] rounded-full bg-club-yellow/10 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute -left-24 top-40 -z-10 h-72 w-[120%] -rotate-3 bg-gradient-to-r from-club-red/25 via-club-red/5 to-transparent blur-2xl"
        aria-hidden="true"
      >
      </div>

      <div class="container-x pt-40 pb-16 sm:pt-48 sm:pb-20">
        <div class="max-w-3xl">
          <span
            class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-[0.32em] text-club-yellow"
          >
            <span class="h-px w-8 bg-club-yellow"></span>
            Jeugd
          </span>

          <h1 class="display mt-6 text-4xl leading-tight text-white sm:text-5xl lg:text-6xl">
            Trainingsuren
          </h1>

          <span class="mt-6 block h-1.5 w-24 rounded-full bg-club-yellow"></span>

          <p class="mt-8 max-w-2xl text-lg text-white/80">
            Hieronder vind je de trainingsdagen en -uren per leeftijdscategorie. De
            trainingen starten in de eerste week van augustus. Iedereen welkom om
            mee te komen trainen!
          </p>

          <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-5">
            <button
              type="button"
              data-open-signup
              class="btn-primary w-full sm:w-auto"
            >
              Schrijf je kind in
              <span aria-hidden="true">→</span>
            </button>
            <p class="text-sm text-white/60">
              Snel invulformulier, in een paar tellen ingeschreven.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-20 sm:pb-28">
      <div class="container-x">
        <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            categories.map((cat) => (
              <li class="team-card is-jeugd flex flex-col">
                <span class="text-[11px] font-bold uppercase tracking-[0.22em] text-club-yellow">
                  Leeftijd
                </span>
                <span class="mt-2 text-3xl font-extrabold tracking-display text-white">
                  {cat.categorie}
                </span>

                <dl class="mt-6 space-y-4 text-sm">
                  <div>
                    <dt class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/50">
                      Training
                    </dt>
                    <dd class="mt-1 space-y-1.5">
                      {cat.dagen.map((moment) => {
                        const isNote = moment.startsWith('Tweede training');
                        return isNote ? (
                          <div
                            class="text-sm leading-relaxed text-white/70"
                            set:html={moment}
                          />
                        ) : (
                          <div class="text-base font-semibold text-white">
                            {moment}
                          </div>
                        );
                      })}
                    </dd>
                  </div>
                  {cat.trainer && (
                    <div>
                      <dt class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/50">
                        Trainer
                      </dt>
                      <dd class="mt-1 text-base text-white/85">{cat.trainer}</dd>
                    </div>
                  )}
                </dl>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="border-t border-white/10 bg-anthracite py-20 sm:py-24">
      <div class="container-x">
        <div class="max-w-3xl">
          <span class="eyebrow text-club-yellow">Praktisch</span>
          <h2 class="section-title mt-4 text-white">Goed om te weten.</h2>
          <span class="accent-bar mt-6"></span>
        </div>

        <dl class="mt-12 grid gap-6 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-ink-deep p-7">
            <dt class="text-xs font-bold uppercase tracking-[0.22em] text-club-yellow">
              Startdatum
            </dt>
            <dd class="mt-3 text-lg font-semibold text-white">{startdatum}</dd>
          </div>

          <div class="rounded-2xl border border-white/10 bg-ink-deep p-7">
            <dt class="text-xs font-bold uppercase tracking-[0.22em] text-club-yellow">
              Locatie
            </dt>
            <dd class="mt-3 text-lg font-semibold text-white">{locatie}</dd>
          </div>

          <div class="rounded-2xl border border-club-red/40 bg-gradient-to-br from-club-red/20 via-anthracite to-anthracite p-7 sm:col-span-2 sm:p-8">
            <dt class="text-xs font-bold uppercase tracking-[0.22em] text-club-yellow">
              Inschrijven of vragen?
            </dt>
            <dd class="mt-4 flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between sm:gap-8">
              <div>
                <p class="text-lg font-semibold text-white">
                  Vul het formulier in met de gegevens van je kind, dan is de inschrijving in orde.
                </p>
                <p class="mt-2 text-sm text-white/70">
                  Rechtstreeks mailen kan ook naar{' '}
                  <a
                    href={`mailto:${jeugdEmail}`}
                    class="font-semibold text-white underline decoration-club-yellow decoration-2 underline-offset-4 transition hover:text-club-yellow"
                  >
                    {jeugdEmail}
                  </a>
                </p>
              </div>
              <button
                type="button"
                data-open-signup
                class="btn-primary w-full shrink-0 sm:w-auto"
              >
                Schrijf je kind in
                <span aria-hidden="true">→</span>
              </button>
            </dd>
          </div>
        </dl>

        <div class="mt-14">
          <a href="/" class="btn-outline-light">
            <span aria-hidden="true">←</span>
            Terug naar home
          </a>
        </div>
      </div>
    </section>

    <div
      id="signup-modal"
      class="hidden fixed inset-0 z-50 overflow-y-auto"
      role="dialog"
      aria-modal="true"
      aria-labelledby="signup-title"
      tabindex="-1"
    >
      <div
        id="signup-backdrop"
        class="fixed inset-0 bg-black/75 backdrop-blur-sm"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 flex min-h-full items-center justify-center p-4 sm:p-6">
        <div
          class="relative w-full max-w-lg rounded-2xl border border-white/10 bg-anthracite p-6 shadow-2xl shadow-black/60 ring-1 ring-club-yellow/10 sm:p-8"
        >
          <button
            id="signup-close"
            type="button"
            aria-label="Sluit inschrijvingsformulier"
            class="absolute right-4 top-4 inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/15 bg-ink-deep text-white/80 transition hover:border-club-red hover:text-white"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
            </svg>
          </button>

          <span class="eyebrow text-club-yellow">Inschrijving</span>
          <h2
            id="signup-title"
            class="mt-3 pr-10 text-2xl font-extrabold tracking-display text-white sm:text-3xl"
          >
            Schrijf je kind in
          </h2>
          <p class="mt-2 text-sm text-white/70">
            Vul de gegevens hieronder in, dan is je kind ingeschreven.
          </p>

          <div
            id="signup-success"
            role="status"
            aria-live="polite"
            hidden
            class="mt-6 rounded-xl border-2 border-emerald-400/60 bg-emerald-500/15 p-6 text-center sm:p-8"
          >
            <span
              class="mx-auto inline-flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500 text-white"
              aria-hidden="true"
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m5 12 5 5 9-11" />
              </svg>
            </span>
            <h3 class="mt-4 text-xl font-extrabold tracking-tight text-white">
              Bedankt!
            </h3>
            <p class="mt-2 text-sm text-white/85">
              We hebben je inschrijving goed ontvangen. Tot op de training!
            </p>
            <button
              type="button"
              data-close-signup
              class="btn-outline-light mt-6"
            >
              Sluiten
            </button>
          </div>

          <form
            id="signup-form"
            novalidate
            class="mt-6 space-y-4"
            aria-describedby="signup-error"
          >
            <div>
              <label for="signup-naam-kind" class="mb-1.5 block text-sm font-medium text-white">
                Naam kind <span class="text-club-yellow" aria-hidden="true">*</span>
              </label>
              <input
                id="signup-naam-kind"
                name="naamKind"
                type="text"
                autocomplete="off"
                required
                class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
              />
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label
                  for="signup-geboortejaar"
                  class="mb-1.5 block text-sm font-medium text-white"
                >
                  Geboortejaar <span class="text-club-yellow" aria-hidden="true">*</span>
                </label>
                <input
                  id="signup-geboortejaar"
                  name="geboortejaar"
                  type="number"
                  inputmode="numeric"
                  min="2000"
                  max="2030"
                  placeholder="Bv. 2018"
                  required
                  class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
                />
              </div>

              <div>
                <label
                  for="signup-categorie"
                  class="mb-1.5 block text-sm font-medium text-white"
                >
                  Leeftijdscategorie <span class="text-club-yellow" aria-hidden="true">*</span>
                </label>
                <select
                  id="signup-categorie"
                  name="categorie"
                  required
                  class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
                >
                  <option value="" disabled selected>Kies…</option>
                  <option value="U6 - U7">U6 - U7</option>
                  <option value="U8">U8</option>
                  <option value="U10">U10</option>
                  <option value="U11">U11</option>
                  <option value="U12">U12</option>
                  <option value="U14">U14</option>
                  <option value="U17">U17</option>
                </select>
              </div>
            </div>

            <div>
              <label
                for="signup-naam-ouder"
                class="mb-1.5 block text-sm font-medium text-white"
              >
                Naam ouder/voogd <span class="text-club-yellow" aria-hidden="true">*</span>
              </label>
              <input
                id="signup-naam-ouder"
                name="naamOuder"
                type="text"
                autocomplete="name"
                required
                class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
              />
            </div>

            <div>
              <label for="signup-email" class="mb-1.5 block text-sm font-medium text-white">
                E-mail <span class="text-club-yellow" aria-hidden="true">*</span>
              </label>
              <input
                id="signup-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
              />
            </div>

            <div>
              <label for="signup-telefoon" class="mb-1.5 block text-sm font-medium text-white">
                Telefoon <span class="text-club-yellow" aria-hidden="true">*</span>
              </label>
              <input
                id="signup-telefoon"
                name="telefoon"
                type="tel"
                autocomplete="tel"
                required
                class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
              />
            </div>

            <div class="absolute -left-[9999px]" aria-hidden="true">
              <label for="signup-website-url">Website URL</label>
              <input
                id="signup-website-url"
                name="website_url"
                type="text"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <button
              id="signup-submit"
              type="submit"
              class="btn-primary w-full disabled:cursor-not-allowed disabled:opacity-70"
            >
              <span data-state="idle">Inschrijving versturen</span>
              <span data-state="loading" class="hidden">Verzenden…</span>
            </button>

            <div
              id="signup-error"
              role="alert"
              aria-live="polite"
              class="hidden items-start gap-3 rounded-xl border border-club-red/60 bg-club-red/20 p-4 text-sm text-white"
            >
              <svg
                class="mt-0.5 h-5 w-5 flex-none text-white"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16h.01" />
              </svg>
              <span id="signup-error-text" class="font-medium"></span>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
  <Footer />

  <script>
    const modal = document.getElementById('signup-modal') as HTMLDivElement | null;
    const backdrop = document.getElementById('signup-backdrop') as HTMLDivElement | null;
    const closeBtn = document.getElementById('signup-close') as HTMLButtonElement | null;
    const openTriggers = document.querySelectorAll<HTMLElement>('[data-open-signup]');
    const closeTriggers = document.querySelectorAll<HTMLElement>('[data-close-signup]');
    const form = document.getElementById('signup-form') as HTMLFormElement | null;
    const successPanel = document.getElementById('signup-success') as HTMLDivElement | null;
    const errorPanel = document.getElementById('signup-error') as HTMLDivElement | null;
    const errorText = document.getElementById('signup-error-text') as HTMLSpanElement | null;
    const submitBtn = document.getElementById('signup-submit') as HTMLButtonElement | null;
    const firstField = document.getElementById('signup-naam-kind') as HTMLInputElement | null;

    if (
      modal &&
      backdrop &&
      closeBtn &&
      form &&
      successPanel &&
      errorPanel &&
      errorText &&
      submitBtn
    ) {
      const idleLabel = submitBtn.querySelector<HTMLSpanElement>('[data-state="idle"]');
      const loadingLabel = submitBtn.querySelector<HTMLSpanElement>('[data-state="loading"]');

      let previouslyFocused: HTMLElement | null = null;

      const clearError = () => {
        errorPanel.classList.add('hidden');
        errorPanel.classList.remove('flex');
        errorText.textContent = '';
      };

      const resetPanels = () => {
        clearError();
        successPanel.hidden = true;
        form.hidden = false;
        form.reset();
      };

      const openModal = () => {
        previouslyFocused = document.activeElement as HTMLElement | null;
        modal.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
        setTimeout(() => firstField?.focus(), 0);
      };

      const closeModal = () => {
        modal.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
        resetPanels();
        previouslyFocused?.focus?.();
      };

      openTriggers.forEach((t) => t.addEventListener('click', openModal));
      closeTriggers.forEach((t) => t.addEventListener('click', closeModal));
      closeBtn.addEventListener('click', closeModal);
      backdrop.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      });

      const showError = (message: string) => {
        errorText.textContent = message;
        errorPanel.classList.remove('hidden');
        errorPanel.classList.add('flex');
      };

      const showSuccess = () => {
        form.hidden = true;
        successPanel.hidden = false;
      };

      const setLoading = (loading: boolean) => {
        submitBtn.disabled = loading;
        idleLabel?.classList.toggle('hidden', loading);
        loadingLabel?.classList.toggle('hidden', !loading);
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        clearError();

        const data = new FormData(form);
        const payload = {
          naamKind: String(data.get('naamKind') ?? '').trim(),
          geboortejaar: String(data.get('geboortejaar') ?? '').trim(),
          categorie: String(data.get('categorie') ?? '').trim(),
          naamOuder: String(data.get('naamOuder') ?? '').trim(),
          email: String(data.get('email') ?? '').trim(),
          telefoon: String(data.get('telefoon') ?? '').trim(),
          website_url: String(data.get('website_url') ?? ''),
        };

        if (
          !payload.naamKind ||
          !payload.geboortejaar ||
          !payload.categorie ||
          !payload.naamOuder ||
          !payload.email ||
          !payload.telefoon
        ) {
          showError('Vul alstublieft alle velden in.');
          return;
        }

        setLoading(true);
        try {
          const response = await fetch('/api/inschrijving', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (response.ok) {
            showSuccess();
          } else {
            const body = (await response.json().catch(() => ({}))) as {
              error?: string;
            };
            showError(body.error ?? 'Er ging iets mis. Probeer het opnieuw.');
          }
        } catch {
          showError('Er ging iets mis met de verbinding. Probeer het opnieuw.');
        } finally {
          setLoading(false);
        }
      });
    }
  </script>
</Layout>
