---
// TODO: vul echte contactgegevens en URL's in
const club = {
  address: '[Straat en nummer], [Postcode] Peer',
  email: 'info@peersv.be',
  phone: '+32 000 00 00 00',
  phoneHref: 'tel:+3200000000',
  // TODO: vervang door echte URL voor wedstrijden & uitslagen
  resultsUrl: 'https://www.voetbalvlaanderen.be/club/[clubnummer]',
};
---

<section id="contact" class="section section-dark">
  <div class="container-x">
    <div class="max-w-3xl">
      <span class="eyebrow">Contact &amp; Lid worden</span>
      <h2 class="section-title mt-4">Kom langs of stuur een bericht.</h2>
      <span class="accent-bar mt-6"></span>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2">
      <form
        id="contact-form"
        novalidate
        class="rounded-2xl border border-white/10 bg-anthracite p-7 sm:p-8 space-y-5 shadow-2xl shadow-black/40"
        aria-describedby="form-status"
      >
        <div>
          <label for="naam" class="mb-1.5 block text-sm font-medium text-white">
            Naam <span class="text-club-yellow" aria-hidden="true">*</span>
          </label>
          <input
            id="naam"
            name="naam"
            type="text"
            autocomplete="name"
            required
            class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
          />
        </div>

        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-white">
            E-mail <span class="text-club-yellow" aria-hidden="true">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            required
            class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
          />
        </div>

        <div>
          <label for="telefoon" class="mb-1.5 block text-sm font-medium text-white">
            Telefoonnummer
          </label>
          <input
            id="telefoon"
            name="telefoon"
            type="tel"
            autocomplete="tel"
            class="w-full rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
          />
        </div>

        <div>
          <label for="bericht" class="mb-1.5 block text-sm font-medium text-white">
            Je bericht <span class="text-club-yellow" aria-hidden="true">*</span>
          </label>
          <textarea
            id="bericht"
            name="bericht"
            rows="5"
            required
            placeholder="Vraag, suggestie, of interesse om lid te worden?"
            class="w-full resize-y rounded-lg border border-white/15 bg-ink-deep px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition focus:border-club-red focus:ring-1 focus:ring-club-red"
          ></textarea>
        </div>

        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="website_url">Website URL</label>
          <input
            id="website_url"
            name="website_url"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="btn-primary w-full disabled:cursor-not-allowed disabled:opacity-70"
        >
          <span data-state="idle">Verstuur bericht</span>
          <span data-state="loading" class="hidden">Verzenden…</span>
        </button>

        <p
          id="form-status"
          role="status"
          aria-live="polite"
          class="text-sm text-white/80"
          data-status="idle"
        >
        </p>
      </form>

      <aside class="flex flex-col gap-6">
        <div class="rounded-2xl border border-white/10 bg-anthracite p-7 sm:p-8">
          <h3 class="text-lg font-extrabold tracking-tight text-white">Vind ons</h3>
          <ul class="mt-5 space-y-4 text-sm">
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 flex-none text-club-yellow"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12Z"
                ></path>
                <circle cx="12" cy="9" r="2.5" stroke-linecap="round" stroke-linejoin="round"></circle>
              </svg>
              <div>
                <p class="font-semibold text-white">Adres</p>
                <p class="text-white/70">{club.address}</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 flex-none text-club-yellow"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 6h16v12H4z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="m4 7 8 6 8-6"></path>
              </svg>
              <div>
                <p class="font-semibold text-white">E-mail</p>
                <a
                  href={`mailto:${club.email}`}
                  class="text-white/70 transition hover:text-club-red"
                >
                  {club.email}
                </a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 flex-none text-club-yellow"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M22 16.92V21a1 1 0 0 1-1.09 1 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 3.21 4.1 1 1 0 0 1 4.2 3h4.09a1 1 0 0 1 1 .75c.12.96.34 1.9.66 2.81a1 1 0 0 1-.23 1.05L7.91 9.43a16 16 0 0 0 6 6l1.82-1.82a1 1 0 0 1 1.05-.23c.91.32 1.85.54 2.81.66a1 1 0 0 1 .75 1Z"
                ></path>
              </svg>
              <div>
                <p class="font-semibold text-white">Telefoon</p>
                <a
                  href={club.phoneHref}
                  class="text-white/70 transition hover:text-club-red"
                >
                  {club.phone}
                </a>
              </div>
            </li>
          </ul>
        </div>

        <a
          href={club.resultsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex items-center justify-between gap-4 overflow-hidden rounded-2xl border border-club-red/40 bg-gradient-to-br from-club-red/20 via-anthracite to-anthracite p-7 transition-all duration-200 hover:-translate-y-0.5 hover:border-club-red"
        >
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-club-yellow">
              Voetbal Vlaanderen
            </p>
            <p class="mt-2 text-xl font-extrabold tracking-display text-white">
              Wedstrijden &amp; uitslagen
            </p>
            <p class="mt-1 text-sm text-white/70">
              Bekijk de actuele kalender en standen.
            </p>
          </div>
          <span
            class="inline-flex h-11 w-11 flex-none items-center justify-center rounded-full bg-club-yellow text-ink transition group-hover:bg-white"
            aria-hidden="true"
          >
            →
          </span>
        </a>
      </aside>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  if (form && status && submitBtn) {
    const idleLabel = submitBtn.querySelector<HTMLSpanElement>('[data-state="idle"]');
    const loadingLabel = submitBtn.querySelector<HTMLSpanElement>('[data-state="loading"]');

    const setStatus = (state: 'idle' | 'success' | 'error', message: string) => {
      status.dataset.status = state;
      status.textContent = message;
      status.classList.remove('text-emerald-400', 'text-club-yellow');
      if (state === 'success') status.classList.add('text-emerald-400');
      if (state === 'error') status.classList.add('text-club-yellow');
    };

    const setLoading = (loading: boolean) => {
      submitBtn.disabled = loading;
      idleLabel?.classList.toggle('hidden', loading);
      loadingLabel?.classList.toggle('hidden', !loading);
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('idle', '');

      const data = new FormData(form);
      const payload = {
        naam: String(data.get('naam') ?? '').trim(),
        email: String(data.get('email') ?? '').trim(),
        telefoon: String(data.get('telefoon') ?? '').trim(),
        bericht: String(data.get('bericht') ?? '').trim(),
        website_url: String(data.get('website_url') ?? ''),
      };

      if (!payload.naam || !payload.email || !payload.bericht) {
        setStatus('error', 'Vul alstublieft alle verplichte velden in.');
        return;
      }

      setLoading(true);
      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          form.reset();
          setStatus(
            'success',
            'Bedankt! Je bericht is verstuurd. We nemen snel contact op.',
          );
        } else {
          const body = (await response.json().catch(() => ({}))) as { error?: string };
          setStatus(
            'error',
            body.error ?? 'Er ging iets mis. Probeer het opnieuw.',
          );
        }
      } catch {
        setStatus(
          'error',
          'Er ging iets mis met de verbinding. Probeer het opnieuw.',
        );
      } finally {
        setLoading(false);
      }
    });
  }
</script>
