---
const year = new Date().getFullYear();
// TODO: vervang door echte social URL's, of verwijder de items die niet bestaan
const socials: ReadonlyArray<{ label: string; href: string; icon: 'facebook' | 'instagram' }> = [
  { label: 'K. Peer SV op Facebook', href: 'https://www.facebook.com/peersv', icon: 'facebook' },
  { label: 'K. Peer SV op Instagram', href: 'https://www.instagram.com/peersv', icon: 'instagram' },
];
---

<footer class="relative bg-black text-white/80">
  <div class="h-1 w-full bg-gradient-to-r from-club-red via-club-yellow to-club-red" aria-hidden="true"></div>

  <div class="container-x py-12">
    <div class="flex flex-col items-start gap-8 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4">
        <span class="logo-badge h-12 w-12">
          <img src="/logo.png" alt="K. Peer SV" class="h-10 w-10 object-contain" />
        </span>
        <div>
          <p class="text-base font-extrabold tracking-tight text-white">K. Peer SV</p>
          <p class="text-sm text-white/55">
            &copy; {year} K. Peer SV. Alle rechten voorbehouden.
          </p>
        </div>
      </div>

      <ul class="flex items-center gap-3">
        {
          socials.map((social) => (
            <li>
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/15 text-white/75 transition hover:-translate-y-0.5 hover:border-club-red hover:bg-club-red hover:text-white"
              >
                {social.icon === 'instagram' ? (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.22.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.05.41 2.22.06 1.26.07 1.64.07 4.85s0 3.6-.07 4.85c-.05 1.17-.25 1.8-.41 2.22a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.42.16-1.05.36-2.22.41-1.26.06-1.64.07-4.85.07s-3.6 0-4.85-.07c-1.17-.05-1.8-.25-2.22-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.05-.41-2.22C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.85c.05-1.17.25-1.8.41-2.22.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.05-.36 2.22-.41C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.5 0-4.74.07-1.07.05-1.66.23-2.05.38-.51.2-.88.44-1.27.83-.39.39-.63.76-.83 1.27-.15.39-.33.98-.38 2.05C2.66 8.5 2.66 8.85 2.66 12s0 3.5.07 4.74c.05 1.07.23 1.66.38 2.05.2.51.44.88.83 1.27.39.39.76.63 1.27.83.39.15.98.33 2.05.38 1.24.07 1.59.07 4.74.07s3.5 0 4.74-.07c1.07-.05 1.66-.23 2.05-.38.51-.2.88-.44 1.27-.83.39-.39.63-.76.83-1.27.15-.39.33-.98.38-2.05.07-1.24.07-1.59.07-4.74s0-3.5-.07-4.74c-.05-1.07-.23-1.66-.38-2.05a3 3 0 0 0-.83-1.27 3 3 0 0 0-1.27-.83c-.39-.15-.98-.33-2.05-.38C15.5 4 15.15 4 12 4Zm0 3.05a4.95 4.95 0 1 1 0 9.9 4.95 4.95 0 0 1 0-9.9Zm0 1.8a3.15 3.15 0 1 0 0 6.3 3.15 3.15 0 0 0 0-6.3Zm5.15-2.03a1.16 1.16 0 1 1 0 2.32 1.16 1.16 0 0 1 0-2.32Z" />
                  </svg>
                ) : (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M13.5 22v-8h2.7l.4-3.1H13.5V8.9c0-.9.25-1.5 1.55-1.5h1.65V4.6c-.3 0-1.3-.1-2.45-.1-2.43 0-4.1 1.5-4.1 4.2v2.2H7.5V14h2.65v8h3.35Z" />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
