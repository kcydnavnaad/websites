---
---

<section
  id="sfeer"
  class="relative isolate overflow-hidden bg-ink-deep text-white"
>
  <div class="absolute inset-0 -z-20" aria-hidden="true">
    <img
      src="/team.jpg"
      alt=""
      class="h-full w-full object-cover object-center"
    />
  </div>

  <div
    class="absolute inset-0 -z-10 bg-gradient-to-r from-ink-deep/95 via-ink-deep/75 to-club-red/45"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 -z-10 bg-black/30"
    aria-hidden="true"
  >
  </div>

  <div class="container-x py-28 sm:py-36">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.22em] text-club-yellow drop-shadow-[0_2px_8px_rgba(0,0,0,0.65)]">
        Seizoen 2025-2026
      </span>
      <h2 class="display mt-4 text-4xl text-white drop-shadow-[0_3px_16px_rgba(0,0,0,0.75)] sm:text-5xl lg:text-6xl">
        Samen op het veld, samen sterker.
      </h2>
      <p class="mt-6 max-w-xl text-lg text-white/90 drop-shadow-[0_2px_10px_rgba(0,0,0,0.7)]">
        Elke ploeg, elke training, elke wedstrijd: dat is K. Peer SV.
        Een familie die week in, week uit voor mekaar gaat.
      </p>
    </div>
  </div>
</section>
