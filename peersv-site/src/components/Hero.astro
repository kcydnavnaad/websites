---
---

<section
  id="home"
  class="relative isolate overflow-hidden bg-ink-deep text-white"
>
  <div class="absolute inset-0 -z-20" aria-hidden="true">
    <img
      src="/veld.jpg"
      alt=""
      class="h-full w-full object-cover"
    />
  </div>

  <div
    class="absolute inset-0 -z-10 bg-gradient-to-br from-black/85 via-black/65 to-club-red/55"
    aria-hidden="true"
  >
  </div>

  <div
    class="pointer-events-none absolute -right-32 top-32 -z-10 h-[420px] w-[420px] -rotate-12 bg-club-yellow/15 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-24 bottom-0 -z-10 h-72 w-[140%] -rotate-3 bg-gradient-to-r from-club-red/40 via-club-red/10 to-transparent blur-2xl"
    aria-hidden="true"
  >
  </div>

  <div class="container-x relative pt-40 pb-28 sm:pt-48 sm:pb-36 lg:pt-56 lg:pb-44">
    <div class="max-w-3xl">
      <span
        class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-[0.32em] text-club-yellow"
      >
        <span class="h-px w-8 bg-club-yellow"></span>
        K. Peer SV <span class="text-white/70">•</span> Peer
      </span>

      <h1
        class="display mt-6 text-6xl leading-[0.95] text-white sm:text-7xl lg:text-[8.5rem]"
      >
        Peer SV
      </h1>

      <span class="mt-8 block h-1.5 w-24 rounded-full bg-club-yellow"></span>

      <p class="mt-8 max-w-xl text-lg text-white/80 sm:text-xl">
        {/* TODO: tagline aanpassen naar wens van het bestuur */}
        Voetbal met hart, in eigen streek.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a href="#contact" class="btn-primary">
          Lid worden
          <span aria-hidden="true">→</span>
        </a>
        <a href="#teams" class="btn-outline-light">
          Bekijk onze ploegen
        </a>
      </div>
    </div>
  </div>

  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-paper"
    aria-hidden="true"
  >
  </div>
</section>
