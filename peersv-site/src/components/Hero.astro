{/*
  TODO: vervang het achtergrond-image-pad hieronder door een foto van het veld.
  Plaats het bestand in public/ (bv. public/veld.jpg) en pas de URL aan.
*/}
<section
  id="home"
  class="relative overflow-hidden pt-32 sm:pt-40"
>
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-soft"
    aria-hidden="true"
  >
    {/* Achtergrondfoto van het veld. Voor nu uitgeschakeld; verwijder hidden zodra de foto aanwezig is. */}
    <img
      src="/veld.jpg"
      alt=""
      class="hidden h-full w-full object-cover opacity-30"
      aria-hidden="true"
    />
  </div>

  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow mb-5">
        <span class="h-1.5 w-1.5 rounded-full bg-club-red"></span>
        Voetbalclub
      </span>

      <h1 class="text-5xl font-extrabold tracking-tight text-ink sm:text-6xl lg:text-7xl">
        PeerSV
      </h1>

      <span class="mx-auto mt-6 block h-1 w-16 rounded-full bg-club-yellow"></span>

      <p class="mt-6 text-lg text-muted sm:text-xl">
        {/* TODO: tagline aanpassen naar wens van het bestuur */}
        Voetbal met hart, in eigen streek.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="#contact" class="btn-primary w-full sm:w-auto">
          Lid worden
          <span aria-hidden="true">→</span>
        </a>
        <a href="#teams" class="btn-outline w-full sm:w-auto">
          Bekijk onze ploegen
        </a>
      </div>
    </div>
  </div>
</section>
